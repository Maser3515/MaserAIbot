# Copy this file to `.env` and fill in the real values.

# Telegram bot token from BotFather
BOT_TOKEN=your_bot_token_here

# Telegram user ID of the admin who will receive notifications and can use admin commands
ADMIN_ID=123456789

# Course information
COURSE_TITLE=ChatGPT для работы
COURSE_PRICE=499

# Payment settings
# Choose payment mode: manual_link or webhook
PAYMENT_MODE=manual_link

# For manual_link mode, provide a link to your payment page or leave blank to use manual instructions
PAYMENT_URL=https://example.com/pay
PAYMENT_PROVIDER_NAME=External payment

# For webhook mode, provide a secret token to validate incoming webhooks
PAYMENT_WEBHOOK_SECRET=change_me

# Yookassa settings (for automatic payments)
# Set PAYMENT_MODE=yookassa to enable
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Path to SQLite database file
DB_PATH=bot.db